{
	"version": 2,
	"functions": {
		"api/*.js": {
			"memory": 1024,
			"maxDuration": 10
		}
	},
	"headers": [
		{
			"source": "/(.*)",
			"headers": [
				{ "key": "Access-Control-Allow-Origin", "value": "*" },
				{ "key": "Access-Control-Allow-Methods", "value": "GET,POST" },
				{
					"key": "Access-Control-Allow-Headers",
					"value": "X-CSRF-Token, X-Requested-With, Accept, Accept-Version, Content-Length, Content-MD5, Content-Type, Date, X-Api-Version"
				}
			]
		}
	],
	"redirects": [
		{
			"source": "/index",
			"destination": "/"
		},
		{
			"source": "/index/",
			"destination": "/"
		},
		{
			"source": "/(.*)",
			"statusCode": 404,
			"destination": "/404/"
		}
	],
	"rewrites": [
		{
			"source": "/api/doc",
			"destination": "/api/doc"
		},
		{
			"source": "/api/doc/swagger.json",
			"destination": "/api/doc"
		},
		{
			"source": "/api/:path*/:action",
			"destination": "/api/:path*"
		},
		{
			"source": "/",
			"destination": "/index/"
		}
	]
}
