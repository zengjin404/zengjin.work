{
	"version": 2,
	"functions": {
		"api/**/*.js": {
			"memory": 1024,
			"maxDuration": 10
		}
	},
	"headers": [
		{
			"source": "/(.*)",
			"headers": [
				{ "key": "Access-Control-Allow-Origin", "value": "*" },
				{ "key": "Access-Control-Allow-Methods", "value": "GET,POST" },
				{
					"key": "Access-Control-Allow-Headers",
					"value": "X-CSRF-Token, X-Requested-With, Accept, Accept-Version, Content-Length, Content-MD5, Content-Type, Date, X-Api-Version, Authorization"
				}
			]
		}
	],
	"redirects": [
		{
			"source": "/index",
			"destination": "/"
		},
		{
			"source": "/index/",
			"destination": "/"
		}
	],
	"rewrites": [
		{
			"has": [{ "type": "host", "value": "api.zengjin.work" }],
			"source": "/:path*",
			"destination": "https://zengjin.work/api/:path*"
		},
		{
			"source": "/api/:path*",
			"destination": "/api/index.js"
		},
		{
			"source": "/",
			"destination": "/index"
		}
	],
	"crons": [
		{
			"path": "/api/base/keepalive/supabase",
			"schedule": "0 3 * * *"
		}
	]
}
